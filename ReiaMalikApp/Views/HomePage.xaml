<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReiaMalikApp.Views.HomePage"
             Title="Accueil Pokédex">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="20" VerticalOptions="Center">

            <Label Text="Bienvenue Dresseurs !" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   TextColor="#CC0000" />

            <Label Text="Prêts à tous les attraper ?" 
                   FontSize="18" 
                   HorizontalOptions="Center" 
                   TextColor="Gray" />

            <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                <Image Source="icon_pokedex.png" HeightRequest="100" WidthRequest="100" />

                <Image Source="pikachu_sprite.png" HeightRequest="100" WidthRequest="100" />
            </HorizontalStackLayout>

            <Border Stroke="LightGray" 
                Padding="15" 
                Margin="0,10,0,0"
                StrokeThickness="1">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="Black" 
                Offset="0,2" 
                Opacity="0.2" 
                Radius="5" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="10">
                    <Label Text="Radar Pokémon actif..." HorizontalOptions="Center" FontAttributes="Bold"/>
                    <ActivityIndicator IsRunning="True" Color="#CC0000" />
                </VerticalStackLayout>

            </Border>

            <Button x:Name="BtnSecret"
                    Text="Voir l'animation secrète" 
                    Clicked="OnSecretButtonClicked"
                    BackgroundColor="#3366CC" 
                    TextColor="White" 
                    CornerRadius="25" 
                    HeightRequest="50"
                    Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>