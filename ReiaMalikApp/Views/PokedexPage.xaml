<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ReiaMalikApp.Models"
             x:Class="ReiaMalikApp.Views.PokedexPage"
             Title="Pokédex"
             BackgroundColor="#1A1A1D">

    <Grid RowDefinitions="Auto, Auto, *">

        <SearchBar Grid.Row="0"
                   Placeholder="Rechercher un Pokémon..."
                   TextChanged="OnSearchTextChanged"
                   TextColor="White"
                   PlaceholderColor="#A0A0A0"
                   BackgroundColor="#2D2D30"
                   Margin="10,10,10,5" />

        <Frame Grid.Row="1"
               BackgroundColor="#2D2D30"
               BorderColor="Transparent"
               CornerRadius="8"
               Padding="0"
               Margin="10,5,10,10"
               MinimumHeightRequest="60">
            <Picker x:Name="GenerationPicker"
                    Title="Sélectionner une génération"
                    SelectedIndexChanged="OnGenerationChanged"
                    TextColor="White"
                    TitleColor="White"
                    VerticalOptions="Center"
                    Margin="10,0,10,0">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Génération 1</x:String>
                        <x:String>Génération 2</x:String>
                        <x:String>Génération 3</x:String>
                        <x:String>Génération 4</x:String>
                        <x:String>Génération S</x:String>
                        <x:String>Pokémon Capturés 🌍</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
        </Frame>

        <Grid Grid.Row="2">
            <CollectionView ItemsSource="{Binding Pokemons}"
                            SelectionMode="Single"
                            SelectionChanged="OnPokemonSelected"
                            Margin="10,0,10,0">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="15" HorizontalItemSpacing="15" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Pokemon">
                        <Frame BackgroundColor="#2D2D30"
                               CornerRadius="12"
                               Padding="10"
                               BorderColor="Transparent"
                               HasShadow="True">
                            <StackLayout Spacing="5">
                                <Image Source="{Binding ImageUrl}"
                                       HeightRequest="100"
                                       WidthRequest="100"
                                       Aspect="AspectFit"
                                       HorizontalOptions="Center" />
                                <Label Text="{Binding Name}"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       FontSize="16"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="{Binding Type1}"
                                       TextColor="#A0A0A0"
                                       FontSize="12"
                                       HorizontalOptions="Center" />
                            </StackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Image x:Name="SpinningPokeball"
                   Source="pokeball_logo.png"
                   HeightRequest="60"
                   WidthRequest="60"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   IsVisible="{Binding IsLoading}" />
        </Grid>
    </Grid>
</ContentPage>