<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ReiaMalikApp.Models"
             xmlns:viewmodels="clr-namespace:ReiaMalikApp.ViewModels"
             x:Class="ReiaMalikApp.Views.PokedexPage"
             x:DataType="viewmodels:PokedexViewModel"
             Title="Pokédex National">

    <Grid>
        <ActivityIndicator IsRunning="{Binding IsBusy}" 
                           IsVisible="{Binding IsBusy}" 
                           HorizontalOptions="Center" 
                           VerticalOptions="Center" 
                           Color="#CC0000" />

        <CollectionView ItemsSource="{Binding Pokemons}" 
                        SelectionMode="None"
                        Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Pokemon">
                    <Frame Margin="5" Padding="10" CornerRadius="10" BorderColor="LightGray" HasShadow="True">
                        <HorizontalStackLayout Spacing="20" VerticalOptions="Center">

                            <Image Source="{Binding ImageUrl}" 
                                   HeightRequest="80" 
                                   WidthRequest="80" />

                            <Label Text="{Binding Name}" 
                                   FontSize="20" 
                                   FontAttributes="Bold" 
                                   VerticalOptions="Center" 
                                   TextColor="#333333" />

                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>