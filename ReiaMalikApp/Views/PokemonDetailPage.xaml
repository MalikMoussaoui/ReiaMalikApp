<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:ReiaMalikApp.ViewModels"
             x:Class="ReiaMalikApp.Views.PokemonDetailPage"
             x:DataType="viewmodels:PokemonDetailViewModel"
             Title="{Binding SelectedPokemon.Name}"
             BackgroundColor="#F5F5F5">
    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <Grid HeightRequest="300">
                <BoxView Color="#CC0000" VerticalOptions="FillAndExpand" />
                <Frame Margin="0,40,0,-40" 
                       CornerRadius="30" 
                       HorizontalOptions="Center" 
                       VerticalOptions="End"
                       HeightRequest="220" 
                       WidthRequest="220"
                       Padding="10"
                       HasShadow="True"
                       BorderColor="White">
                    <Image Source="{Binding SelectedPokemon.ImageUrl}" 
                           Aspect="AspectFit" />
                </Frame>
            </Grid>

            <VerticalStackLayout Padding="25" Spacing="20" Margin="0,30,0,0">

                <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                    <Label Text="{Binding SelectedPokemon.Name}" 
                           FontSize="32" 
                           FontAttributes="Bold" 
                           TextColor="#333333"
                           HorizontalOptions="Center" />

                    <Frame BackgroundColor="#EE6666" 
                           CornerRadius="20" 
                           Padding="15,4" 
                           BorderColor="Transparent"
                           HorizontalOptions="Center">
                        <Label Text="{Binding SelectedPokemon.Type}" 
                               TextColor="White" 
                               FontSize="12" 
                               FontAttributes="Bold"/>
                    </Frame>
                </VerticalStackLayout>

                <Frame CornerRadius="20" Padding="20" HasShadow="True" BorderColor="Transparent">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="DESCRIPTION" 
                               FontSize="14" 
                               FontAttributes="Bold" 
                               TextColor="#CC0000" />

                        <Label Text="{Binding SelectedPokemon.Description}" 
                               FontSize="16" 
                               TextColor="#555555" 
                               LineHeight="1.2" />

                        <BoxView Color="#EEEEEE" HeightRequest="1" HorizontalOptions="Fill" />

                        <HorizontalStackLayout Spacing="30" HorizontalOptions="Center">
                            <VerticalStackLayout HorizontalOptions="Center">
                                <Label Text="HP" FontAttributes="Bold" HorizontalOptions="Center"/>
                                <Label Text="{Binding SelectedPokemon.HP}" TextColor="Gray" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout HorizontalOptions="Center">
                                <Label Text="ATK" FontAttributes="Bold" HorizontalOptions="Center"/>
                                <Label Text="{Binding SelectedPokemon.Attack}" TextColor="Gray" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout HorizontalOptions="Center">
                                <Label Text="DEF" FontAttributes="Bold" HorizontalOptions="Center"/>
                                <Label Text="{Binding SelectedPokemon.Defense}" TextColor="Gray" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <Button Text="Retour au Pokédex" 
                        Clicked="OnBackButtonClicked"
                        BackgroundColor="#CC0000" 
                        TextColor="White" 
                        CornerRadius="25" 
                        HeightRequest="50"
                        FontAttributes="Bold"
                        Margin="0,10,0,30" />

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>