<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:ReiaMalikApp.ViewModels"
             x:Class="ReiaMalikApp.Views.PokemonDetailPage"
             x:DataType="viewmodels:PokemonDetailViewModel"
             Title="{Binding SelectedPokemon.Name}"
             BackgroundColor="#FFFFFF">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <Grid HeightRequest="300" BackgroundColor="#F2F2F2">
                <Image Source="{Binding SelectedPokemon.ImageUrl}" Aspect="AspectFit" Margin="20" />
            </Grid>

            <VerticalStackLayout Padding="25" Spacing="20">

                <Label Text="{Binding SelectedPokemon.Description}" 
                       FontSize="18" 
                       TextColor="#212121" 
                       LineHeight="1.3" />

                <Frame BackgroundColor="#30A7D7" CornerRadius="10" Padding="20" HasShadow="False" BorderColor="Transparent">
                    <Grid RowDefinitions="Auto, 20, Auto" ColumnDefinitions="*, *" ColumnSpacing="20">

                        <VerticalStackLayout Grid.Row="0" Grid.Column="0">
                            <Label Text="Taille" TextColor="White" FontSize="16" />
                            <Label Text="{Binding SelectedPokemon.Height}" TextColor="#212121" FontSize="20" FontAttributes="Bold" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                            <Label Text="Catégorie" TextColor="White" FontSize="16" />
                            <Label Text="{Binding SelectedPokemon.Category}" TextColor="#212121" FontSize="20" FontAttributes="Bold" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="2" Grid.Column="0">
                            <Label Text="Poids" TextColor="White" FontSize="16" />
                            <Label Text="{Binding SelectedPokemon.Weight}" TextColor="#212121" FontSize="20" FontAttributes="Bold" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="2" Grid.Column="1">
                            <Label Text="Talent" TextColor="White" FontSize="16" />
                            <Label Text="{Binding SelectedPokemon.Ability}" TextColor="#212121" FontSize="20" FontAttributes="Bold" />
                        </VerticalStackLayout>

                    </Grid>
                </Frame>

                <Label Text="Type" FontSize="20" FontAttributes="Bold" TextColor="#333333" Margin="0,10,0,0"/>
                <Frame BackgroundColor="#FD7D24" CornerRadius="5" Padding="20,5" HorizontalOptions="Start" BorderColor="Transparent">
                    <Label Text="{Binding SelectedPokemon.Type}" TextColor="White" FontAttributes="Bold" FontSize="16"/>
                </Frame>

                <Button Text="Retour au Pokédex" 
                        Clicked="OnBackButtonClicked"
                        BackgroundColor="#E3350D" 
                        TextColor="White" 
                        CornerRadius="5" 
                        HeightRequest="50"
                        FontAttributes="Bold"
                        Margin="0,20,0,30" />

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>