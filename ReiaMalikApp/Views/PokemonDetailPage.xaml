<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:ReiaMalikApp.ViewModels"
             x:Class="ReiaMalikApp.Views.PokemonDetailPage"
             x:DataType="viewmodels:PokemonDetailViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{Binding SelectedPokemon.GenerationColor}">

    <Grid RowDefinitions="220, *">
        <VerticalStackLayout Grid.Row="0" Padding="20,50,20,0">
            <Button Text="🡠 Retour" Clicked="OnBackButtonClicked" BackgroundColor="Transparent" TextColor="White" HorizontalOptions="Start" FontAttributes="Bold" FontSize="18" Padding="0"/>
        </VerticalStackLayout>

        <Frame Grid.Row="1" BackgroundColor="White" CornerRadius="45" Margin="0,-40,0,-10" Padding="25,110,25,25" HasShadow="False" BorderColor="Transparent">
            <ScrollView VerticalScrollBarVisibility="Never">
                <VerticalStackLayout Spacing="25">

                    <VerticalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Label Text="{Binding SelectedPokemon.Name}" FontSize="36" FontAttributes="Bold" TextColor="#2C3E50" HorizontalOptions="Center"/>

                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                            <Frame BackgroundColor="{Binding SelectedPokemon.Type1Color}" Padding="15,6" CornerRadius="20" BorderColor="Transparent" HasShadow="False">
                                <Label Text="{Binding SelectedPokemon.Type1}" TextColor="White" FontAttributes="Bold" FontSize="14"/>
                            </Frame>
                            <Frame BackgroundColor="{Binding SelectedPokemon.Type2Color}" Padding="15,6" CornerRadius="20" BorderColor="Transparent" HasShadow="False" IsVisible="{Binding SelectedPokemon.HasType2}">
                                <Label Text="{Binding SelectedPokemon.Type2}" TextColor="White" FontAttributes="Bold" FontSize="14"/>
                            </Frame>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <Label Text="{Binding SelectedPokemon.Description}" FontSize="16" TextColor="#666666" LineHeight="1.5" HorizontalTextAlignment="Center" Margin="0,5,0,5"/>

                    <Frame BackgroundColor="#F8F9FA" CornerRadius="25" Padding="20" HasShadow="False" BorderColor="#E9ECEF">
                        <Grid RowDefinitions="Auto, 20, Auto" ColumnDefinitions="*, *" ColumnSpacing="20">
                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" HorizontalOptions="Center">
                                <Label Text="Taille" TextColor="#A0A0A0" FontSize="14" HorizontalOptions="Center"/>
                                <Label Text="{Binding SelectedPokemon.Height}" TextColor="#2C3E50" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="0" Grid.Column="1" HorizontalOptions="Center">
                                <Label Text="Poids" TextColor="#A0A0A0" FontSize="14" HorizontalOptions="Center"/>
                                <Label Text="{Binding SelectedPokemon.Weight}" TextColor="#2C3E50" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="2" Grid.Column="0" HorizontalOptions="Center">
                                <Label Text="Catégorie" TextColor="#A0A0A0" FontSize="14" HorizontalOptions="Center"/>
                                <Label Text="{Binding SelectedPokemon.Category}" TextColor="#2C3E50" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="2" Grid.Column="1" HorizontalOptions="Center">
                                <Label Text="Talent" TextColor="#A0A0A0" FontSize="14" HorizontalOptions="Center"/>
                                <Label Text="{Binding SelectedPokemon.Ability}" TextColor="#2C3E50" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>

                    <Label Text="Statistiques de Base" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50" Margin="0,10,0,0"/>

                    <HorizontalStackLayout Spacing="25" HorizontalOptions="Center">
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Frame BackgroundColor="#E9ECEF" CornerRadius="30" HeightRequest="60" WidthRequest="60" Padding="0" HasShadow="False" BorderColor="Transparent">
                                <Label Text="{Binding SelectedPokemon.HP}" VerticalOptions="Center" HorizontalOptions="Center" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"/>
                            </Frame>
                            <Label Text="PV" HorizontalOptions="Center" FontSize="13" FontAttributes="Bold" TextColor="#A0A0A0" Margin="0,8,0,0"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout HorizontalOptions="Center">
                            <Frame BackgroundColor="#E9ECEF" CornerRadius="30" HeightRequest="60" WidthRequest="60" Padding="0" HasShadow="False" BorderColor="Transparent">
                                <Label Text="{Binding SelectedPokemon.Attack}" VerticalOptions="Center" HorizontalOptions="Center" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"/>
                            </Frame>
                            <Label Text="ATK" HorizontalOptions="Center" FontSize="13" FontAttributes="Bold" TextColor="#A0A0A0" Margin="0,8,0,0"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout HorizontalOptions="Center">
                            <Frame BackgroundColor="#E9ECEF" CornerRadius="30" HeightRequest="60" WidthRequest="60" Padding="0" HasShadow="False" BorderColor="Transparent">
                                <Label Text="{Binding SelectedPokemon.Defense}" VerticalOptions="Center" HorizontalOptions="Center" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"/>
                            </Frame>
                            <Label Text="DEF" HorizontalOptions="Center" FontSize="13" FontAttributes="Bold" TextColor="#A0A0A0" Margin="0,8,0,0"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </ScrollView>
        </Frame>

        <Frame Grid.Row="0" Grid.RowSpan="2" BackgroundColor="Transparent" CornerRadius="100" HeightRequest="200" WidthRequest="200" VerticalOptions="Start" Margin="0,50,0,0" HorizontalOptions="Center" BorderColor="Transparent" Padding="0" IsClippedToBounds="True" HasShadow="False">
            <Image Source="{Binding SelectedPokemon.ImageUrl}" Aspect="AspectFill" HeightRequest="200" WidthRequest="200" HorizontalOptions="Center" VerticalOptions="Center"/>
        </Frame>
    </Grid>
</ContentPage>