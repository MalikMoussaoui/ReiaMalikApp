<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:ReiaMalikApp.ViewModels"
             x:Class="ReiaMalikApp.Views.PokemonDetailPage"
             x:DataType="viewmodels:PokemonDetailViewModel"
             Title="{Binding SelectedPokemon.Name}">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20" HorizontalOptions="Center">

            <Frame BorderColor="#CC0000" CornerRadius="100" HeightRequest="200" WidthRequest="200" Padding="0" IsClippedToBounds="True" HorizontalOptions="Center">
                <Image Source="{Binding SelectedPokemon.ImageUrl}" Aspect="AspectFill" />
            </Frame>

            <Label Text="{Binding SelectedPokemon.Name}" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" />

            <Frame BackgroundColor="#F5F5F5" 
                   BorderColor="#CC0000"
                   CornerRadius="15" 
                   Padding="20"
                   HasShadow="True">

                <Label Text="{Binding SelectedPokemon.Description}" 
                       FontSize="18" 
                       TextColor="#333333" 
                       HorizontalOptions="Center" 
                       HorizontalTextAlignment="Center"
                       FontAttributes="Italic"/>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>