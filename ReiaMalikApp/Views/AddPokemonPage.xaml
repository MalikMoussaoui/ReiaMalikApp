<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReiaMalikApp.Views.AddPokemonPage"
             Title="Nouveau Pokémon"
             BackgroundColor="#1A1A1D">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20,20,20,40">

            <Label Text="CRÉER UN POKÉMON" FontSize="24" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" Margin="0,0,0,10"/>

            <Frame BackgroundColor="#2C2C2E" CornerRadius="15" Padding="15" BorderColor="Transparent" HasShadow="False">
                <VerticalStackLayout Spacing="15">

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Nom du Pokémon *" TextColor="#8E8E93" FontSize="12" FontAttributes="Bold"/>
                        <Entry x:Name="NameEntry" Placeholder="Ex: Pikachou" PlaceholderColor="#666666" TextColor="White" BackgroundColor="Transparent" ClearButtonVisibility="WhileEditing"/>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#3A3A3C"/>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Type Principal *" TextColor="#8E8E93" FontSize="12" FontAttributes="Bold"/>
                        <Picker x:Name="Type1Picker" Title="Sélectionner le 1er type" TitleColor="#666666" TextColor="White" BackgroundColor="Transparent">
                            <Picker.Items>
                                <x:String>ACIER</x:String>
                                <x:String>COMBAT</x:String>
                                <x:String>DRAGON</x:String>
                                <x:String>EAU</x:String>
                                <x:String>ELECTRIK</x:String>
                                <x:String>FÉE</x:String>
                                <x:String>FEU</x:String>
                                <x:String>GLACE</x:String>
                                <x:String>INSECTE</x:String>
                                <x:String>NORMAL</x:String>
                                <x:String>PLANTE</x:String>
                                <x:String>POISON</x:String>
                                <x:String>PSY</x:String>
                                <x:String>ROCHE</x:String>
                                <x:String>SOL</x:String>
                                <x:String>SPECTRE</x:String>
                                <x:String>TÉNÈBRES</x:String>
                                <x:String>VOL</x:String>
                            </Picker.Items>
                        </Picker>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#3A3A3C"/>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Type Secondaire (Optionnel)" TextColor="#8E8E93" FontSize="12" FontAttributes="Bold"/>
                        <Picker x:Name="Type2Picker" Title="Sélectionner le 2ème type" TitleColor="#666666" TextColor="White" BackgroundColor="Transparent">
                            <Picker.Items>
                                <x:String>AUCUN</x:String>
                                <x:String>ACIER</x:String>
                                <x:String>COMBAT</x:String>
                                <x:String>DRAGON</x:String>
                                <x:String>EAU</x:String>
                                <x:String>ELECTRIK</x:String>
                                <x:String>FÉE</x:String>
                                <x:String>FEU</x:String>
                                <x:String>GLACE</x:String>
                                <x:String>INSECTE</x:String>
                                <x:String>NORMAL</x:String>
                                <x:String>PLANTE</x:String>
                                <x:String>POISON</x:String>
                                <x:String>PSY</x:String>
                                <x:String>ROCHE</x:String>
                                <x:String>SOL</x:String>
                                <x:String>SPECTRE</x:String>
                                <x:String>TÉNÈBRES</x:String>
                                <x:String>VOL</x:String>
                            </Picker.Items>
                        </Picker>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#3A3A3C"/>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Image (URL ou Galerie)" TextColor="#8E8E93" FontSize="12" FontAttributes="Bold"/>
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                            <Entry Grid.Column="0" x:Name="ImageUrlEntry" Placeholder="https://..." PlaceholderColor="#666666" TextColor="White" BackgroundColor="Transparent"/>
                            <Button Grid.Column="1" Text="📸 Galerie" Clicked="OnPickImageClicked" BackgroundColor="#3A3A3C" TextColor="White" CornerRadius="10" Padding="10,0" HeightRequest="40"/>
                        </Grid>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="#2C2C2E" CornerRadius="15" Padding="15" BorderColor="Transparent" HasShadow="False">
                <VerticalStackLayout Spacing="15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Description" TextColor="#8E8E93" FontSize="12" FontAttributes="Bold"/>
                        <Editor x:Name="DescriptionEditor" Placeholder="Il aime manger des baies..." PlaceholderColor="#666666" TextColor="White" BackgroundColor="Transparent" HeightRequest="80" AutoSize="TextChanges"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="#2C2C2E" CornerRadius="15" Padding="15" BorderColor="Transparent" HasShadow="False">
                <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *, *" ColumnSpacing="15" RowSpacing="15">
                    <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="5">
                        <Label Text="PV" TextColor="#8E8E93" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Entry x:Name="HpEntry" Text="50" Keyboard="Numeric" TextColor="White" BackgroundColor="#3A3A3C" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="5">
                        <Label Text="ATK" TextColor="#8E8E93" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Entry x:Name="AtkEntry" Text="50" Keyboard="Numeric" TextColor="White" BackgroundColor="#3A3A3C" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Row="0" Grid.Column="2" Spacing="5">
                        <Label Text="DEF" TextColor="#8E8E93" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Entry x:Name="DefEntry" Text="50" Keyboard="Numeric" TextColor="White" BackgroundColor="#3A3A3C" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="1" Spacing="5">
                        <Label Text="Taille (m)" TextColor="#8E8E93" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Entry x:Name="HeightEntry" Text="1.0" Keyboard="Numeric" TextColor="White" BackgroundColor="#3A3A3C" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Spacing="5">
                        <Label Text="Poids (kg)" TextColor="#8E8E93" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Entry x:Name="WeightEntry" Text="10.0" Keyboard="Numeric" TextColor="White" BackgroundColor="#3A3A3C" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <Button Text="AJOUTER À LA GÉNÉRATION S" Clicked="OnSaveButtonClicked" BackgroundColor="#E3350D" TextColor="White" FontAttributes="Bold" CornerRadius="25" HeightRequest="50" Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>